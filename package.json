{
  "name": "solar-system-simulation",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "npm run typecheck && npm test && npm run build && npm run test:e2e",
    "test:watch": "vitest",
    "build:launcher": "powershell -ExecutionPolicy Bypass -File tools/build-launcher.ps1",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "gifenc": "^1.0.3",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/three": "^0.184.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
